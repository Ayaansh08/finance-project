{
  "name": "@finance-project/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",

    "postinstall": "prisma generate",

    "test": "vitest run",
    "test:watch": "vitest",

    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_models",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.7",
    "prisma": "^6.0.0",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}